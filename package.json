{
  "name": "nexgen-pdf-viewer",
  "private": false,
  "version": "1.0.2",
  "description": "A professional, high-performance PDF viewer component for React projects. Built with performance and flexibility in mind.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/nexgen-pdf-viewer.umd.cjs",
  "module": "./dist/nexgen-pdf-viewer.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nexgen-pdf-viewer.js",
      "require": "./dist/nexgen-pdf-viewer.umd.cjs"
    },
    "./package.json": "./package.json"
  },
  "keywords": [
    "pdf",
    "pdf-viewer",
    "viewer",
    "react",
    "annotation",
    "highlight",
    "notes",
    "react-component",
    "typescript",
    "javascript",
    "pdf.js",
    "document-viewer",
    "ui-component"
  ],
  "author": "Md. Imran Shaikh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skimu5802-code/NexPDFViewer.git"
  },
  "homepage": "https://github.com/skimu5802-code/NexPDFViewer#readme",
  "bugs": {
    "url": "https://github.com/skimu5802-code/NexPDFViewer/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "build:lib": "vite build --config vite.config.ts --mode library",
    "preview": "vite preview",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run clean && npm run build:lib && npm run lint"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.546.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.4.168",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.1",
    "motion": "^12.23.24",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-css-injected-by-js": "^5.0.1",
    "vite-plugin-dts": "^5.0.0"
  }
}
